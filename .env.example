# Copy to .env and fill in values before running

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# JWT token lifetime in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated static API keys (leave empty to disable API key auth)
API_KEYS=my-secret-key-1,my-secret-key-2

# Built-in admin account for JWT login (leave ADMIN_PASSWORD empty to disable)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
